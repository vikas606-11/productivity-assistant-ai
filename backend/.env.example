# ──────────────────────────────────────────────────────────────────────────────
# Productivity Assistant AI — Backend Environment Variables
# Copy this file to .env and fill in the real values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# Flask server settings
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=true

# Secret key used for session signing (generate a strong random value in prod)
SECRET_KEY=your-secret-key-here

# SQLite database file path (relative to backend/)
DATABASE_URI=./productivity_assistant.db

# Google Gemini API
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-pro

# Frontend origin (used for CORS allowlist)
FRONTEND_URL=http://localhost:5173
